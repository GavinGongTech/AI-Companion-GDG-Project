{
  "name": "gdg-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "web",
    "extension",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "dev:web": "npm run dev --workspace=web",
    "dev:extension": "npm run dev --workspace=extension",
    "dev:server": "npm run dev --workspace=server",
    "dev:all": "concurrently -n web,ext,srv -c blue,green,magenta \"npm run dev:web\" \"npm run dev:extension\" \"npm run dev:server\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
