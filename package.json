{
  "name": "gdg-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "web",
    "extension",
    "server"
  ],
  "scripts": {
    "setup": "bun run ./scripts/setup.mjs",
    "doctor": "bun run ./scripts/doctor.mjs",
    "dev": "bun run ./scripts/workspace-runner.mjs dev",
    "dev:web": "bun run --cwd web dev",
    "dev:extension": "bun run --cwd extension dev",
    "dev:server": "bun run --cwd server dev",
    "dev:all": "bun run ./scripts/workspace-runner.mjs dev",
    "build": "bun run ./scripts/workspace-runner.mjs build && bun run package:extension",
    "package:extension": "bun run ./scripts/package-extension.mjs",
    "lint": "bun run ./scripts/workspace-runner.mjs lint",
    "typecheck": "bun run ./scripts/workspace-runner.mjs typecheck",
    "test": "bun run ./scripts/workspace-runner.mjs test",
    "check": "bun run ./scripts/workspace-runner.mjs check"
  }
}
