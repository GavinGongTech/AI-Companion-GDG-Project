PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL + pgvector. Run locally with: docker compose up -d
DATABASE_URL=postgresql://studyflow:studyflow@localhost:5432/studyflow

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Google / Gemini ───────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Path to a Google Cloud service account JSON (for Cloud Vision OCR)
# Leave blank if not using OCR
GOOGLE_APPLICATION_CREDENTIALS=

# ── LMS OAuth (Brightspace / Canvas) ─────────────────────────────────────────
LMS_CLIENT_ID=
LMS_CLIENT_SECRET=
LMS_REDIRECT_URI=http://localhost:3000/api/v1/auth/lms/callback
