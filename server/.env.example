PORT=3000
NODE_ENV=development

# ── Google / Gemini ───────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Firebase ─────────────────────────────────────────────────────────────────
# Option 1: Path to a service account JSON (also used for Cloud Vision OCR)
GOOGLE_APPLICATION_CREDENTIALS=

# Option 2: Just the project ID (uses Application Default Credentials)
FIREBASE_PROJECT_ID=
