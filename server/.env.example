PORT=3000
NODE_ENV=development

# ── Google / Gemini ───────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_FAST_MODEL=gemini-2.0-flash

# ── Prompt Graphify (token reduction) ──────────────────────────────────────────
# Enables graph-based prompt compaction for all Gemini calls.
GRAPHIFY_ENABLED=true
GRAPHIFY_QUESTION_MAX_TOKENS=220
GRAPHIFY_CONTEXT_MAX_TOKENS=1200
GRAPHIFY_ANSWER_MAX_TOKENS=450
GRAPHIFY_MATERIAL_MAX_TOKENS=1400

# ── Firebase ─────────────────────────────────────────────────────────────────
# Option 1: Path to a service account JSON (also used for Cloud Vision OCR)
GOOGLE_APPLICATION_CREDENTIALS=

# Option 2: Just the project ID (uses Application Default Credentials)
FIREBASE_PROJECT_ID=

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Leave blank for permissive (dev only).
# Example: https://studyflow.app,chrome-extension://your-extension-id
ALLOWED_ORIGINS=
