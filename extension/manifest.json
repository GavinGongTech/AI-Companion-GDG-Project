{
  "manifest_version": 3,
  "name": "Study Flow",
  "version": "0.0.1",
  "description": "Contextual math study assistant — Ask, Quiz, and course-aware help.",
  "action": {
    "default_title": "Open Study Flow"
  },
  "side_panel": {
    "default_path": "dist/sidepanel.html"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "scripting",
    "identity"
  ],
  "oauth2": {
    "client_id": "966291933098-6ikkt690ieircck9sn321nh7v64952cs.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/userinfo.email", "https://www.googleapis.com/auth/userinfo.profile"]
  },
  "externally_connectable": {
    "matches": ["http://localhost:5173/*", "http://127.0.0.1:5173/*"]
  },
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.brightspace.com/*",
        "*://brightspace.nyu.edu/*",
        "*://*.gradescope.com/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
